# ── Database ─────────────────────────────────────────────────────
# Local: docker-compose Postgres on :5433.
# Railway: provisioned by the Postgres plugin; the auto-generated URL
# includes ?sslmode=require, which Railway Postgres requires.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/conaro_dev

# ── Auth.js ──────────────────────────────────────────────────────
# Required in production. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Local dev only. In production behind an HTTPS reverse proxy (e.g. Railway),
# remove AUTH_URL and set AUTH_TRUST_HOST=true instead.
AUTH_URL=http://localhost:3000

# Production behind an HTTPS reverse proxy (Railway, Vercel, Fly, etc.):
# uncomment so Auth.js trusts the X-Forwarded-* headers from the proxy.
# AUTH_TRUST_HOST=true

# ── Cron ─────────────────────────────────────────────────────────
# Shared bearer token for the events-lifecycle tick endpoint
# (/api/cron/events/tick). Any random string; rotate periodically.
CRON_SECRET=

# Demo database reset cron (issue #18). DO NOT enable on production.
# Bearer token for POST /api/cron/db-reset. Generate with: openssl rand -base64 32
CRON_RESET_SECRET=
# Opt-in guard. Must be exactly "true" for the reset endpoint to do anything.
ENABLE_DB_RESET=false